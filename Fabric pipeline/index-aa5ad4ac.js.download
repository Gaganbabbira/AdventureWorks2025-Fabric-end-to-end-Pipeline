ar",hideObjectExplorer:"Sembunyikan Peneroka Objek",showObjectExplorer:"Tunjukkan Peneroka Objek",searchError:"Tidak dapat menyelesaikan carian. Sila cuba hantar carian anda sekali lagi.",emptyStateTitle:"Tidak menemui sebarang hasil carian",emptyStateDescription:"Ubah kata kunci anda dan cuba lagi.",emptyStateTitleV2:"Tidak dapat menemukan hasil untuk carian anda",emptyStateDescriptionV2:"Ubah kata kunci atau penapis anda dan cuba lagi.",emptyWorkspaceObjectId:"Tidak dapat mengambil objectId ruang kerja",loadingResultsFor:'Memuatkan keputusan untuk "{{query}}"...',showingResultsFor:'Menunjukkan {{count}} hasil untuk "{{query}}"',showingXOfManyResultsFor:'Memaparkan {{count}} daripada banyak hasil untuk "{{query}}"',results:"keputusan",outputParameterName:"output",outputType:"Output",inputType:"Input"},AQe={closeAllTabs:"Tutup Semua Tab",manageTabs:"Urus Tab"},zQe={toolbarButtonLabel:"Salin pertanyaan",toolbarButtonTooltip:"Salin teks pertanyaan, hasil atau pautan untuk membuka pertanyaan dalam aplikasi lain.",buttonUnavailableEmptyTooltip:"Tersedia apabila terdapat teks pertanyaan atau hasil untuk disalin",buttonUnavailableExplainTooltip:"Terima atau tolak penerangan sebelum menyalin pertanyaan",buttonUnavailableTooLongTooltip:"Teks pertanyaan terlalu panjang untuk menggunakan Salin pertanyaan. Sebaliknya, pilih teks tersebut, kemudian gunakan Ctrl+C untuk menyalinnya.",dialogTitle:"Salin pertanyaan (Pratonton)",copyQueryCandidateLabel:"Pilih perkara yang ingin disalin",copyCandidate:{link:"Pautan untuk membuka pertanyaan yang disalin",queryText:"Teks pertanyaan",result:"Hasil"},showPreview:"Pratonton papan klip",emptyPreviewContent:"Pilih perkara yang ingin disalin",fabricLinkLabel:"Fabric",ssmsLinkLabel:"SSMS",openInPrefix:"Buka dalam ",linkUnavailableTooltip:"Teks pertanyaan terlalu panjang untuk dikongsi sebagai pautan.",noQuerySelectedTooltip:"Tiada teks pertanyaan untuk dikongsi sebagai pautan.",resultAvailableTooltip:"Pratonton mungkin tidak menunjukkan hasi