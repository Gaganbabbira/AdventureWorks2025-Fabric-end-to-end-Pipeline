ilTitle:"Không xóa được điểm khôi phục",restorePointSuccessTitle:"Đang khôi phục điểm khôi phục của bạn",restorePointFailTitle:"Không thể khôi phục điểm khôi phục",modifyFailTitle:"Không thể sửa đổi tên điểm khôi phục",pollRestorePointResultSuccessTitle:"Đã khôi phục điểm khôi phục thành công",pollRestorePointResultFailTitle:"Khôi phục điểm khôi phục không thành công"}},UWe={unableToPreviewDataError:"Không thể xem trước dữ liệu",showing1000Rows:"Đang hiển thị 1000 hàng",dataPreviewHeaderTitle:"Xem trước dữ liệu"},WWe={error:{correlationId:"ID tương quan",requestId:"ID yêu cầu",sessionId:"ID phiên"},creatingNewTable:"Đang tạo bảng mới",creatingNewView:"Đang tạo chế độ xem mới",duplicateTableNameError:"Đã tồn tại bảng có cùng tên trong cấu trúc cơ sở dữ liệu đã xác định.",duplicateViewNameError:"Đã tồn tại dạng xem có cùng tên trong sơ đồ cơ sở dữ liệu đã xác định.",generateNewTableWithQuery:"Truy vấn của bạn được sử dụng để tạo bảng mới",generateNewViewWithQuery:"Truy vấn của bạn được sử dụng để tạo chế độ xem mới",generatedNewTableWithQuery:"Truy vấn của bạn đã được sử dụng để tạo bảng mới",generatedNewViewWithQuery:"Truy vấn của bạn đã được sử dụng để tạo chế độ xem mới",invalidCharactersError:"Tên chứa ký tự không hợp lệ.",maxLengthError:"Bạn đã vượt quá giới hạn 128 ký tự",saveAsTable:"Lưu dưới dạng bảng",saveAsView:"Lưu dưới dạng chế độ xem",saveAsTableDialogSqlWarnText:"Để đảm bảo bảng được lưu chính xác, hãy xác minh câu lệnh SQL bạn đang gửi có chứa câu lệnh SQL SELECT.",saveAsViewDialogInfoText:"Thao tác này sẽ lưu văn bản truy vấn SQL của bạn dưới dạng xem. Hãy đảm bảo cú pháp SQL cho dạng xem bên dưới chính xác.",saveAsTableSqlQueryInfoMessage:`Để đảm bảo bảng được lưu chính xác, hãy xác minh câu lệnh SQL bạn đang gửi có chứa câu lệnh SQL SELECT.

 Nếu bạn muốn thay đổi câu lệnh SQL đang gửi, hãy hủy bỏ hộp thoại này. Sau đó, chọn văn bản của câu lệnh SELECT trong trình chỉnh sửa truy vấn và thử lại. (Lưu ý rằng nếu bạn gửi nhiều câu lệnh thì chỉ câu lệnh đầu tiên sẽ được sử dụng.)`,saveAsTableVisualQueryInfoMessage:"Thao tác này sẽ tạo bảng từ kết quả của truy vấn trực quan được áp dụng Cho phép tải. Để sử dụng một truy vấn trực quan khác, hãy hủy bỏ hộp thoại này và áp dụng Cho phép tải đối với truy vấn trực quan bạn muốn sử dụng.",startsWithSpaceErrorTable:"Tên bảng không được bắt đầu bằng dấu cách.",startsWithSpaceErrorView:"Tên chế độ xem không được bắt đầu bằng dấu cách.",successfullySavedAsTable:"Đã lưu bảng mới thành công",successfullySavedAsView:"Đã lưu chế độ xem mới thành công",unableToSaveAsTableContent:"Để lưu dưới dạng bảng, hãy chọn văn bản câu lệnh SELECT trong truy vấn của bạn, rồi thử lại",unableToSaveAsViewContent:"Để lưu dưới dạng chế độ xem, hãy chọn văn bản câu lệnh SELECT trong truy vấn của bạn, rồi thử lại",unableToSaveAsTableTitle:"Không thể lưu dưới dạng bảng",unableToSaveAsViewTitle:"Không thể lưu dưới dạng chế độ xem",failedToLoadArtifact:"Không tải được mục",deleteQueryErrorWithNoPath:"Không thể xóa truy vấn không có đường dẫn",deleteQueryErrorWithIncorrectPath:"Không thể xóa truy vấn có đường dẫn không chính xác",deleteQueryFailure:"Không xóa được các truy vấn sau: {{failedQueries}}",moveQueryError:"Không thể di chuyển các truy vấn sau: {{failedQueries}}",moveQueryErrorWithIncorrectPath:"Không thể di chuyển truy vấn có đường dẫn không chính xác"},HWe={selectNode:"Chọn {{name}}",selectAllInFolder:"Chọn tất cả trong {{name}}"},GWe={addWarehouse:"Thêm kho dữ liệu",explorer:"Trang khám phá",showMore:"Xem thêm",showingXOfMany:"Đang hiển thị {{count}} trong số nhiều",loading:"Đang tải...",failedToLoadChildren:"Không tải được mục con",failedToLoadRoot:"Không tải được gốc.",hideObjectExplorer:"Ẩn Object Explorer",showObjectExplorer:"Hiển thị Object Explorer",searchError:"Không thể