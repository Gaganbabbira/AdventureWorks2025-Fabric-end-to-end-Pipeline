irmation:{sqlStatement:"Câu lệnh SQL",verifySqlSelectStatement1:"Để đảm bảo rằng bạn có thể xuất kết quả truy vấn, hãy xác minh rằng câu lệnh SQL bạn đang gửi bao gồm một câu lệnh SQL SELECT.",verifySqlSelectStatement2:"Nếu bạn muốn thay đổi câu lệnh SQL bạn đang gửi, hãy hủy hộp thoại này. Sau đó, chọn văn bản của câu lệnh SELECT trong trình chỉnh sửa truy vấn và thử lại. (Lưu ý rằng nếu bạn gửi nhiều câu lệnh, chỉ mỗi câu lệnh đầu tiên sẽ được sử dụng.)"}},tHe={copyToClipboard:"Sao chép vào bảng tạm",copied:"Đã sao chép văn bản!",copyAriaLabel:"Sao chép văn bản!",serverNameTitle:"Tên máy chủ",databaseNameTitle:"Tên cơ sở dữ liệu"},aHe={feedbackTitle:"Phản hồi cho trình soạn thảo",feedbackText:"Ý kiến phản hồi",send:"Gửi",notNow:"Lúc khác",feedbackDisclaimerText:"Microsoft sẽ xử lý ý kiến phản hồi mà bạn gửi theo hướng dẫn của tổ chức bạn để cải thiện trải nghiệm của bạn và...",feedbackDisclaimerTooltip:"Microsoft sẽ xử lý phản hồi bạn gửi theo hướng dẫn của tổ chức bạn để cải thiện trải nghiệm của bạn và tổ chức bạn với sản phẩm này. Nếu bạn có bất kỳ câu hỏi nào về việc sử dụng dữ liệu phản hồi, vui lòng liên hệ với quản trị viên đối tượng thuê. Việc xử lý dữ liệu phản hồi chịu sự điều chỉnh của Phụ lục Bảo vệ dữ liệu sản phẩm và dịch vụ của Microsoft giữa tổ chức của bạn và Microsoft, đồng thời phản hồi bạn gửi sẽ được xem là Dữ liệu cá nhân theo phụ lục đó.",feedbackDialogTitle:"Cung cấp ý kiến phản hồi cho Microsoft",feedbackCommentPlaceholder:"Cung cấp càng nhiều chi tiết càng tốt nhưng không bao gồm bất kỳ thông tin riêng tư hoặc nhạy cảm nào.",tellUsMore:"Cho chúng tôi biết thêm",privacyStatement:"Điều khoản về quyền riêng tư",feedbackDisabled:"Quản trị viên CNTT của bạn đã tắt tính năng thu thập phản hồi.",feedbackArialabel:"Xếp hạng phản hồi",individualStarAriaLabel:"{0}/{5} sao"},nHe={overviewTab:"Tổng quan",dataPreviewTab:"Bản xem trước dữ liệu",columns:"Cột",keysAndRelationships:"Ràng buộc",summary:"Tóm tắt",quickActions:"Hành động nhanh",