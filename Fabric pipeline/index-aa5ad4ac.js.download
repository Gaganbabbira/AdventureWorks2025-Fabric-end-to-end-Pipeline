)",downloadAsCsv:"Downloaden als CSV-bestand",downloadAsJson:"Downloaden als .json",copyMessages:"Berichten kopiëren",copy:"Kopiëren",copyResults:"Resultaten kopiëren",copyColumnNames:"Kolomnamen kopiëren",copyResultsWithColumnNames:"Resultaten met kolomnamen kopiëren",failedToCompleteRequest:"Kan het verzoek niet uitvoeren.",userCanceledQuery:"De gebruiker heeft de queryuitvoering geannuleerd. Alle geretourneerde resultaten vindt u op het tabblad Resultaten.",limited10KRows:"Beperkt tot 10.000 rijen",sqlErrorMessage:"Msg {{sqlErrorNumber}}, niveau {{sqlErrorClass}}, status {{sqlErrorState}}, regel {{sqlErrorLineNumber}}",sqlServerExecutionMessage:"Het uitvoeren op regel {{startLine}} is gestart",timeToProcessAndRenderResults:"Tijd om resultaten te verwerken en weer te geven",totalDuration:"Totale duur",expandResultsPane:"Resultatenvenster uitvouwen",collapseResultsPane:"Resultatenvenster samenvouwen",failedToExecute:"Kan de query niet uitvoeren"},WQe={dismiss:"Sluiten"},HQe={addButton:"Een herstelpunt toevoegen",dialog:{createTitle:"Nieuw herstelpunt",createSubtitle:"Velden die zijn gemarkeerd met <1>*</1> zijn vereist",createDescription:"Voeg een beschrijving toe voor dit herstelpunt.",createNameErrorEmpty:"Voer een naam in.",createNameErrorTooLong:"Namen mogen niet langer zijn dan 128 tekens.",createDescriptionTooLong:"Beschrijvingen mogen niet meer dan 512 tekens bevatten.",deleteContent:"Als u de herstelpunten verwijdert: {{restorePoints}}, kunt u het magazijn niet terugzetten naar die status. Wilt u het verwijderen?",deleteTitle:"Herstelpunt verwijderen",restoreTitle:"Magazijn herstellen",restoreContent:"Als u het magazijn herstelt, wordt het volgende gedaan: <1><0>Vervang het huidige schema, de query's en modelindelingen door vorige versies</0><0>Actieve query's voor alle gebruikers annuleren</0><0>Alle web- en tabelgegevensstroom-verbindingen</0><0>Gebruikerstoegangsbeleid vervangen door vorige versies (dit omvat rijniveau, kolomniveau en beveiliging voor dy