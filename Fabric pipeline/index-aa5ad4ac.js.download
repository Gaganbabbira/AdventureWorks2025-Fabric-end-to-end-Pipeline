уку",individualStarAriaLabel:"{0} із {5} зірок"},LWe={overviewTab:"Огляд",dataPreviewTab:"Попередній перегляд даних",columns:"Стовпці",keysAndRelationships:"Обмеження",summary:"Підсумок",quickActions:"Швидкі дії",sqlPermissions:"Дозволи SQL",selectTop100:"ВИБРАТИ ПЕРШІ 100",selectTop100Tooltip:"Переглянути перші 100 рядків",properties:"Властивості",propertiesTooltip:"Показати область властивостей",create:"Переглянути визначення",createTooltip:"Відкрити сценарій CREATE у новій вкладці",cloneTable:"Клонувати таблицю",cloneTableTooltip:"Створити копію цієї таблиці",drop:"DROP",dropTooltip:"Відкрити сценарій DROP у новій вкладці",scriptCtas:"CREATE AS SELECT",scriptCtasTooltip:"Створити нову таблицю на основі запиту SELECT",columnName:"Ім’я стовпця",columnId:"Ідентифікатор стовпця",dataType:"Тип даних",maxLength:"Максимальна довжина",precision:"Точність",scale:"Масштаб",nullable:"З підтримкою Null-значення",yes:"Так",no:"Ні",columnsEmpty:"Стовпців не знайдено",searchColumns:"Пошук стовпців",searchRelationships:"Пошук зв’язків",rowCount:"Рядки",columnCount:"Стовпці",relationshipShowingCount:"Показано зв’язків: {{shown, number}} з {{total, number}}",tableSize:"Розмір",lastModified:"Востаннє змінено",summaryEmpty:"Підсумок недоступний",permissionName:"Дозвіл",permissionStatus:"Стан",granted:"Надано",notGranted:"Не надано",noPermissionsFound:"Дозволів SQL не знайдено",noRelationships:"Без обмежень",noRelationshipsDescription:"Тут відображатимуться обмеження, як-от первинні ключі, зовнішні ключі та унікальні правила.",constraintName:"Ім’я ключа",constraintType:"Тип",keyConstraints:"Ключі",foreignKeyRelationships:"Зв’язки",parentTable:"Вихідна таблиця",parentColumn:"Вихідний стовпець",referencedTable:"Цільова таблиця",referencedColumn:"Цільовий стовпець",openJoinQuery:"Відкрити запит INNER JOIN",noQuerySuggestions:"Ще немає пропозицій",copilotDisabledHint:"Щоб використовувати пропозиції на основі ШІ, попросіть адміністратора ввімкнути Copilot для цієї робочої області.",aiSugg