rtialError:"Không thể di chuyển {{numberOfFailedQueries}} trong số {{totalQueries}} truy vấn đã chọn",bulkMoveAllQueryError:"Không thể di chuyển tất cả truy vấn đã chọn của bạn.",keepRunningTheQueryTitle:"Tiếp tục chạy truy vấn này?",keepRunningTheQueriesTitle:"Tiếp tục chạy các truy vấn này?",keepRunningTheQueryMessage:"Truy vấn này vẫn đang chạy. Bạn có muốn tiếp tục chạy truy vấn này sau khi tab đóng không?",keepRunningTheQueriesMessage:"Một số truy vấn vẫn đang chạy. Bạn có muốn tiếp tục chạy các truy vấn này sau khi tab đóng không?",keepRunningTheQueryButtonTitle:"Có, tiếp tục chạy truy vấn này",keepRunningTheQueriesButtonTitle:"Có, tiếp tục chạy các truy vấn này",cancelQuery:"Không, hủy truy vấn này",cancelQueries:"Không, hủy các truy vấn này",saveChangesDialogTitle:"Lưu các thay đổi?",saveChangesDialogMessage:"Truy vấn này có các thay đổi chưa lưu.",alwaysOnClose:"Luôn thực hiện điều này khi tôi đóng tab truy vấn hoặc trình duyệt",runningQueryTitle:"Đang chạy",completedQueryTitle:"Đã hoàn tất lượt chạy"},QWe={emptyCanvasTitle:"Để xây dựng truy vấn, hãy kéo bảng của bạn vào đây.",nonFoldingLoadEnabledQuery:"Truy vấn này không hỗ trợ việc nén truy vấn.",editSqlScript:"Chỉnh sửa tập lệnh SQL",viewSql:"Xem SQL"},FWe={completedWithErrors:"Đã hoàn thành kèm theo lỗi",succeeded:"Đã thành công",failure:"Lỗi",canceled:"Đã hủy bỏ",cancelling:"Đang hủy",displayTimeHours:"{{hours}} giờ",displayTimeMinutes:"{{minutes}} phút",displayTimeSeconds:"{{seconds}} giây",displayTimeMilliseconds:"{{milliseconds}} mili giây",tableDimensions:"Cột: {{columns}} Hàng: {{rows}}",inlineCompletionDisabledForBigSchema:"Đã tắt tính năng điền vào trong dòng của Copilot vì kích cỡ sơ đồ quá lớn. Kích cỡ token hiện tại {{tokenSize}} lớn hơn giới hạn 400k.",inlineCompletionOn:"Tính năng hoàn thành của Copilot: Đang bật",inlineCompletionOff:"Tính năng hoàn thành của Copilot: Đang tắt",inlineCompletionReady:"Tính năng hoàn thành của Copilot: Sẵn sàng",inlineCompletionRunning:"Tính năng hoàn thà