тването на данни за обратна връзка се регулира от Допълнението за защита на данните за продукти и услуги на Microsoft между вашата организация и Microsoft, а обратната връзка, която подавате, се счита за „лични данни“ съгласно това допълнение.",feedbackDialogTitle:"Изпращане на обратна връзка на Microsoft",feedbackCommentPlaceholder:"Дайте възможно най-много подробности, но не включвайте лична или поверителна информация.",tellUsMore:"Разкажете ни повече",privacyStatement:"Декларация за поверителност",feedbackDisabled:"Колекцията от обратна връзка е дезактивирана от вашия ИТ администратор.",feedbackArialabel:"Оценка на обратната връзка",individualStarAriaLabel:"{0} от {5} звезди"},e8e={overviewTab:"Общ преглед",dataPreviewTab:"Преглед на данни",columns:"Колони",keysAndRelationships:"Ограничения",summary:"Резюме",quickActions:"Бързи действия",sqlPermissions:"Разрешения за SQL",selectTop100:"ИЗБОР НА ПЪРВИТЕ 100",selectTop100Tooltip:"Визуализация на първите 100 реда",properties:"Свойства",propertiesTooltip:"Показване на прозореца със свойства",create:"Преглед на дефиницията",createTooltip:"Отваряне на скрипта СЪЗДАВАНЕ в нов раздел",cloneTable:"Клониране на таблица",cloneTableTooltip:"Създаване на копие на тази таблица",drop:"DROP",dropTooltip:"Отваряне на скрипт за DROP в нов раздел",scriptCtas:"СЪЗДАВАНЕ КАТО ИЗБОР",scriptCtasTooltip:"Създаване на нова таблица от заявка за ИЗБИРАНЕ",columnName:"Име на колона",columnId:"ИД на колона",dataType:"Тип данни",maxLength:"Максимална дължина",precision:"Точност",scale:"Мащаб",nullable:"Позволява стойност null",yes:"Да",no:"Не",columnsEmpty:"Не са намерени колони",searchColumns:"Търсене на колони",searchRelationships:"Търсене на релации",rowCount:"Редове",columnCount:"Колони",relationshipShowingCount:"Показване на {{shown, number}} от {{total, number}} релации",tableSize:"Размер",lastModified:"Последна промяна",summaryEmpty:"Няма налично резюме",permissionName:"Разрешение",permissionStatus:"Състояние",granted:"Предоставено",no